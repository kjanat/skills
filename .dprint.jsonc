{
  "lineWidth": 120,
  "useTabs": false,
  "extends": "https://github.com/kjanat/kjanat/raw/83172ba/configs/dprint.remote.json",
  "excludes": ["**/dist", "**/node_modules", "**/coverage", "**/examples"],
  "exec": {
    "commands": [
      { "command": "tombi format - --stdin-filename {{file_path}}", "exts": ["toml"] },
    ],
  },
  "plugins": [
    "https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463",
  ],
}

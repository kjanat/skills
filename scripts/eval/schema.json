{
  "$id": "https://kjanat.github.io/skills/eval-config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Assertion": {
      "type": "object",
      "required": [
        "op",
        "path"
      ],
      "properties": {
        "name": {
          "description": "Human-readable label shown in benchmark output.",
          "type": "string"
        },
        "op": {
          "type": "string",
          "enum": [
            "equals",
            "not_equals",
            "contains",
            "not_contains",
            "matches",
            "not_matches",
            "truthy",
            "falsy",
            "length_gte",
            "length_lte"
          ]
        },
        "path": {
          "description": "Dotted path into the structured response. Integer segments index into lists. Empty string targets the root.",
          "type": "string"
        },
        "value": {
          "description": "Comparison value. Required for all ops except `truthy`/`falsy`. For `matches`/`not_matches` it is a Python regex string. For `length_gte`/`length_lte` it must be an integer."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": [
              "op"
            ],
            "properties": {
              "op": {
                "const": "truthy"
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "value"
              ]
            }
          }
        },
        {
          "if": {
            "required": [
              "op"
            ],
            "properties": {
              "op": {
                "const": "falsy"
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "value"
              ]
            }
          }
        },
        {
          "if": {
            "required": [
              "op"
            ],
            "properties": {
              "op": {
                "enum": [
                  "matches",
                  "not_matches"
                ]
              }
            }
          },
          "then": {
            "required": [
              "value"
            ],
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "op"
            ],
            "properties": {
              "op": {
                "enum": [
                  "length_gte",
                  "length_lte"
                ]
              }
            }
          },
          "then": {
            "required": [
              "value"
            ],
            "properties": {
              "value": {
                "type": "integer"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "op"
            ],
            "properties": {
              "op": {
                "enum": [
                  "equals",
                  "not_equals",
                  "contains",
                  "not_contains"
                ]
              }
            }
          },
          "then": {
            "required": [
              "value"
            ]
          }
        }
      ]
    },
    "EvalCase": {
      "type": "object",
      "required": [
        "id",
        "json_schema",
        "prompt"
      ],
      "properties": {
        "assertions": {
          "description": "Mechanical checks against the structured response. Empty is allowed but useless.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Assertion"
          }
        },
        "id": {
          "description": "Unique integer id within this file.",
          "type": "integer",
          "minimum": 1
        },
        "json_schema": {
          "$ref": "https://json-schema.org/draft/2020-12/schema",
          "description": "JSON Schema passed to `claude --json-schema`. Constrains the structured output the agent must produce. Validated as a real JSON Schema (Draft 2020-12)."
        },
        "name": {
          "description": "Slug used as the case directory name. Defaults to `eval-<id>`.",
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "prompt": {
          "description": "User-facing task prompt passed to claude as the positional arg.",
          "type": "string",
          "minLength": 1
        },
        "system_prompt": {
          "description": "Optional override for the system prompt. When omitted the runner injects a default that points at SKILL.md.",
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "title": "Skill Eval Config",
  "description": "Schema for skills/<name>/evals/evals.json — the input to scripts/eval/run_eval.py.",
  "type": "object",
  "required": [
    "evals",
    "skill_name"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "evals": {
      "description": "Eval cases — each one is one claude -p invocation.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/EvalCase"
      }
    },
    "skill_name": {
      "description": "Must match the skill's frontmatter name and the skills/<name>/ directory.",
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
